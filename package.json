    "@aws-sdk/credential-providers": "^3.500.0",
    "commander": "^11.1.0",
    "ini": "^4.1.1",
    "inquirer": "^8.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/ini": "^1.3.34",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.3.3",
